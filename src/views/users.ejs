<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1 style="text-align: center;">Welcom to DELTA CMS</h1>
    <h3 style="text-align: center;">In development</h3>

    <h1 style="text-align: center;">Users</h1>
    <ul>
        <% users.forEach(function(user) { %>
            <li>ID: <%= user.id %>, Имя: <%= user.username %>, Возраст: <%= user.age %>, <% if (user.admin === 1) {
                %> Администратор <%
            } %></li>
        <% }); %>
    </ul>
</body>
</html>