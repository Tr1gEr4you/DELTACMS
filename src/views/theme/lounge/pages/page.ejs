<%- include('../partials/head') %>

<div class="user-container page-show">
    <% if (page.status === "published") { %> 
        <h1><%= page.title %></h1>
        <div class="page-content">
          <%- page.content %>
        </div>
    <% } else { %>
        <h1>Страница временно недоступен для использования. Пожалуйста, обратитесь к администратору для получения дополнительной информации.</h1>
    <% } %>
</div>

<%- include('../partials/footer') %>