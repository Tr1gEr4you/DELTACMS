<%- include('../partials/head-admin') %>

<div class="admin-wrapper">
  <%- include('../partials/sidebar-admin') %>

  <main class="admin-main">
    <div class="admin-container">
      <h1>Редактировать сервер</h1>

      <form action="/admin/servers/<%= server.id %>?_method=PUT" method="POST" class="form">
        <div class="form-group">
          <label for="ip">IP сервера</label>
          <input type="text" name="ip" id="ip" class="form-control" value="<%= server.ip %>" required>
        </div>

        <div class="form-group">
          <label for="port">Порт</label>
          <input type="number" name="port" id="port" class="form-control" value="<%= server.port %>" required>
        </div>

        <div class="form-group">
          <label for="rcon_password">RCON пароль</label>
          <input type="text" name="rcon_password" id="rcon_password" class="form-control" value="<%= server.rcon_password %>" required>
        </div>

        <button type="submit" class="btn btn-primary">Обновить</button>
      </form>
    </div>
  </main>
</div>

<%- include('../partials/footer-admin') %>