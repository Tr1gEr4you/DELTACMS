<%- include('../partials/head-admin') %>

<div class="admin-wrapper">
  <%- include('../partials/sidebar-admin') %>

  <main class="admin-main">
    <div class="admin-container">
      <h1>Список серверов</h1>
      <a href="/admin/servers/add" class="btn btn-primary">Добавить сервер</a>

      <table class="table">
        <thead>
          <tr>
            <th>ID</th>
            <th>IP</th>
            <th>Порт</th>
            <th>Действия</th>
          </tr>
        </thead>
        <tbody>
          <% servers.forEach(server => { %>
            <tr>
              <td><%= server.id %></td>
              <td><%= server.ip %></td>
              <td><%= server.port %></td>
              <td>
                <a href="/admin/servers/edit/<%= server.id %>" class="btn btn-warning">Редактировать</a>
                <a href="/admin/servers/rcon/<%= server.id %>" class="btn btn-info">Отправить команду RCON</a>
                <a href="/admin/servers/status/<%= server.id %>" class="btn btn-info">Статистика сервера</a>
                <form action="/admin/servers/<%= server.id %>?_method=DELETE" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-danger">Удалить</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </main>
</div>

<%- include('../partials/footer-admin') %>