<!-- views/admin/header/list.ejs -->
<%- include('../partials/head-admin') %>

<div class="admin-wrapper">
  <%- include('../partials/sidebar-admin') %>

  <main class="admin-main">
    <div class="admin-container">
      <div class="admin-header">
        <h1>Кнопки хедера</h1>
        <a href="/admin/header/add" class="btn">Добавить новую кнопку</a>
      </div>

      <table class="table">
        <thead>
          <tr>
            <th>Название</th>
            <th>URL</th>
            <th>Позиция</th>
            <th>Статус</th>
            <th>Действия</th>
          </tr>
        </thead>
        <tbody>
          <% buttons.forEach(button => { %>
            <tr>
              <td><%= button.label %></td>
              <td><%= button.url %></td>
              <td><%= button.position %></td>
              <td>
                <% if (button.active) { %>
                  <span class="status-active">Активная</span>
                <% } else { %>
                  <span class="status-inactive">Неактивная</span>
                <% } %>
              </td>
              <td>
                <a href="/admin/header/edit/<%= button.id %>" class="btn small">Редактировать</a>
                <form action="/admin/header/<%= button.id %>?_method=DELETE" method="POST" style="display: inline;">
                  <button type="submit" class="btn small danger" onclick="return confirm('Удалить кнопку?')">Удалить</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </main>
</div>

<%- include('../partials/footer-admin') %>