<%- include('../partials/head-admin') %>

<div class="admin-wrapper">
    <%- include('../partials/sidebar-admin') %>

    <main class="admin-main">
      <div class="admin-container">
        <div class="admin-header">
          <h1>Пользователи</h1>
          <a href="/admin/users/add" class="btn">Добавить пользователя</a>
        </div>

        <table class="table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Логин</th>
              <th>Email</th>
              <th>Роль</th>
              <th>Действия</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(user => { %>
              <tr>
                <td><%= user.id %></td>
                <td><%= user.login %></td>
                <td><%= user.email %></td>
                <td><%= user.role_name %></td>
                <td class="action-buttons">
                  <a href="/admin/users/edit/<%= user.id %>" class="btn small">Редактировать</a>
                  <form method="POST" action="/admin/users/<%= user.id %>?_method=DELETE" class="inline-form">
                    <button type="submit" class="btn small danger" onclick="return confirm('Удалить пользователя?')">Удалить</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
  </div>

  <%- include('../partials/footer-admin') %>