<%- include('../partials/head-admin') %>

<div class="admin-wrapper">
  <%- include('../partials/sidebar-admin') %>

  <main class="admin-main">
    <div class="admin-container">
      <div class="admin-header">
        <h1>Страницы</h1>
        <a href="/admin/pages/add" class="btn">Создать новую</a>
      </div>

      <table class="table">
        <thead>
          <tr>
            <th>Заголовок</th>
            <th>Роут</th>
            <th>Статус</th>
            <th>Действия</th>
          </tr>
        </thead>
        <tbody>
          <% pages.forEach(page => { %>
            <tr>
              <td><a href="/pages/<%= page.route %>"><%= page.title %></td>
              <td>/<%= page.route %></td>
              <td>
                <% if (page.status === 'published') { %>
                  <span class="status-active">Опубликована</span>
                <% } else { %>
                  <span class="status-inactive">Черновик</span>
                <% } %>
              </td>
              <td>
                <a href="/admin/pages/edit/<%= page.id %>" class="btn small">Редактировать</a>
                <form action="/admin/pages/<%= page.id %>?_method=DELETE" method="POST" style="display: inline;">
                  <button type="submit" class="btn small danger" onclick="return confirm('Удалить страницу?')">Удалить</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </main>
</div>

<%- include('../partials/footer-admin') %>