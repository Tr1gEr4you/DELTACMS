<%- include('../partials/head-admin') %>

<div class="admin-wrapper">
    <%- include('../partials/sidebar-admin') %>
  
    <main class="admin-main">
      <div class="admin-container">
        <div class="admin-header">
          <h1>📈 Панель статистики</h1>
        </div>
  
        <!-- Карточки статистики -->
        <div class="admin-stats-grid">
          <div class="card stat-card">
            <div class="stat-title">Всего пользователей</div>
            <div class="stat-value"><%= countUsers %></div>
          </div>
        </div>
  
        <!-- Последние пользователи -->
        <div class="section">
          <h2 class="section-title">🕵️ Последние зарегистрированные пользователи</h2>
          <table class="table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Логин</th>
                <th>Email</th>
                <th>Дата регистрации</th>
              </tr>
            </thead>
            <tbody>
              <% latestUsers.forEach(user => { %>
                <tr>
                  <td><%= user.id %></td>
                  <td><%= user.login %></td>
                  <td><%= user.email %></td>
                  <td><%= new Date(user.created_at).toLocaleString('ru-RU') %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
  
        <!-- Регистрации по дням -->
        <div class="section">
          <h2 class="section-title">📅 Регистрации за последние 7 дней</h2>
          <table class="table">
            <thead>
              <tr>
                <th>Дата</th>
                <th>Количество регистраций</th>
              </tr>
            </thead>
            <tbody>
              <% registrationsUsersByDay.forEach(day => { %>
                <tr>
                  <td><%= day.date %></td>
                  <td><%= day.count %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

<%- include('../partials/footer-admin') %>