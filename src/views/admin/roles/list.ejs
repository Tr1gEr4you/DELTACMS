<%- include('../partials/head-admin') %>

<div class="admin-wrapper">
  <%- include('../partials/sidebar-admin') %>

  <main class="admin-main">
    <div class="admin-container">
      <div class="admin-header">
        <h1>Роли пользователей</h1>
        <a href="/admin/roles/add" class="btn">Добавить роль</a>
      </div>

      <table class="table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Название</th>
            <th>Флаги</th>
            <th>Действия</th>
          </tr>
        </thead>
        <tbody>
          <% roles.forEach(role => { %>
            <tr>
              <td><%= role.id %></td>
              <td><%= role.name %></td>
              <td><code><%= role.flags %></code></td>
              <td>
                <a href="/admin/roles/edit/<%= role.id %>" class="btn small">Редактировать</a>
                <form method="POST" action="/admin/roles/<%= role.id %>?_method=DELETE" style="display:inline;">
                  <button type="submit" class="btn small danger" onclick="return confirm('Удалить пользователя?')">Удалить</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </main>
</div>

<%- include('../partials/footer-admin') %>